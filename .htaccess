# ==========================================
# Poshy Lifestyle Store вҖ“ Apache Configuration
# DigitalOcean VPS Production
# ==========================================

# в”Җв”Җв”Җ Rewrite Engine в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RewriteEngine On
RewriteBase /

# в”Җв”Җв”Җ Force HTTPS в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# в”Җв”Җв”Җ HTTP Security Headers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    # XSS filter
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS вҖ“ tells browsers to always use HTTPS (6 months)
    Header always set Strict-Transport-Security "max-age=15768000; includeSubDomains"
    # Permissions policy вҖ“ disable unused browser features
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # Content Security Policy вҖ“ allow Google/Facebook scripts needed for OAuth
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://connect.facebook.net https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; frame-src https://accounts.google.com https://www.facebook.com; connect-src 'self' https://accounts.google.com https://graph.facebook.com"
    # Remove server fingerprinting
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# в”Җв”Җв”Җ Security: Block sensitive files в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
<FilesMatch "\.(env|log|bak|sql|csv|md|py|sh)$">
    Require all denied
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>

# Block access to sensitive file extensions
<FilesMatch "\.(env|log|bak|sql|csv|md|py|sh|ini)$">
    Require all denied
</FilesMatch>

# в”Җв”Җв”Җ Skip real files and directories в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# в”Җв”Җв”Җ Arabic URL Routes в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# Arabic product URLs: /Щ…ЩҶШӘШ¬/product-slug вҶ’ product.php?slug=product-slug&lang=ar
RewriteRule ^%D9%85%D9%86%D8%AA%D8%AC/(.+?)/?$ product.php?slug=$1&lang=ar [L,QSA]
# Alternative: direct UTF-8 match
RewriteRule ^Щ…ЩҶШӘШ¬/(.+?)/?$ product.php?slug=$1&lang=ar [L,QSA]

# Arabic podcast URLs: /ШЁЩҲШҜЩғШ§ШіШӘ вҶ’ podcast.php?lang=ar
RewriteRule ^%D8%A8%D9%88%D8%AF%D9%83%D8%A7%D8%B3%D8%AA/?$ podcast.php?lang=ar [L,QSA]
RewriteRule ^ШЁЩҲШҜЩғШ§ШіШӘ/?$ podcast.php?lang=ar [L,QSA]
RewriteRule ^%D8%A8%D9%88%D8%AF%D9%83%D8%A7%D8%B3%D8%AA/(.+?)/?$ podcast.php?slug=$1&lang=ar [L,QSA]
RewriteRule ^ШЁЩҲШҜЩғШ§ШіШӘ/(.+?)/?$ podcast.php?slug=$1&lang=ar [L,QSA]

# Arabic category browsing: /Щ…ШӘШ¬Шұ вҶ’ index.php?lang=ar
RewriteRule ^%D9%85%D8%AA%D8%AC%D8%B1/?$ index.php?lang=ar [L,QSA]
RewriteRule ^Щ…ШӘШ¬Шұ/?$ index.php?lang=ar [L,QSA]

# Arabic cart: /ШіЩ„Ш© вҶ’ pages/shop/guest_checkout.php?lang=ar
RewriteRule ^%D8%B3%D9%84%D8%A9/?$ pages/shop/guest_checkout.php?lang=ar [L,QSA]
RewriteRule ^ШіЩ„Ш©/?$ pages/shop/guest_checkout.php?lang=ar [L,QSA]

# в”Җв”Җв”Җ Podcast URLs в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# /podcast вҶ’ podcast.php (listing)
# /podcast/my-episode-slug вҶ’ podcast.php?slug=my-episode-slug
RewriteRule ^podcast/?$ podcast.php [L,QSA]
RewriteRule ^podcast/([a-z0-9]+(?:-[a-z0-9]+)*)/?$ podcast.php?slug=$1 [L,QSA]

# в”Җв”Җв”Җ Clean product URLs в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# /the-ordinary-retinol вҶ’ product.php?slug=the-ordinary-retinol
RewriteRule ^([a-z0-9]+(?:-[a-z0-9]+)*)/?$ product.php?slug=$1 [L,QSA]

# в”Җв”Җв”Җ Large File Uploads (500 MB) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
<IfModule mod_php.c>
    php_value upload_max_filesize 500M
    php_value post_max_size 512M
    php_value max_execution_time 600
    php_value max_input_time 600
    php_value memory_limit 256M
</IfModule>

# в”Җв”Җв”Җ Enable compression в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# в”Җв”Җв”Җ Cache static assets в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
