# ==========================================
# Poshy Lifestyle Store – Apache Configuration
# DigitalOcean VPS Production
# ==========================================

# ─── Rewrite Engine ────────────────────────────────────────────────────
RewriteEngine On
RewriteBase /

# ─── Force HTTPS (skip on localhost / local dev) ──────────────────────
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost$ [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1$ [NC]
RewriteCond %{HTTP_HOST} !^192\.168\. [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── 301 redirect old ?lang= query-string URLs to /ar/ path ───────────
# /foo?lang=ar  →  /ar/foo
# /foo?lang=en  →  /foo
RewriteCond %{QUERY_STRING} (^|&)lang=ar(&|$)
RewriteRule ^(.*)$ /ar/$1?%{QUERY_STRING} [R=301,L,QSA]

# Old lang=en also gets cleaned (root = English)
RewriteCond %{QUERY_STRING} (^|&)lang=en(&|$)
RewriteRule ^(.*)$ /$1?%{QUERY_STRING} [R=301,L,QSA]

# ─── HTTP Security Headers ────────────────────────────────────────────
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME sniffing
    Header always set X-Content-Type-Options "nosniff"
    # XSS filter
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # HSTS – tells browsers to always use HTTPS (6 months)
    Header always set Strict-Transport-Security "max-age=15768000; includeSubDomains"
    # Permissions policy – disable unused browser features
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # Content Security Policy – allow Google/Facebook scripts needed for OAuth
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://connect.facebook.net https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https:; frame-src https://accounts.google.com https://www.facebook.com; connect-src 'self' https://accounts.google.com https://graph.facebook.com"
    # Remove server fingerprinting
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ─── Security: Block sensitive files ───────────────────────────────────
<FilesMatch "\.(env|log|bak|sql|csv|md|py|sh)$">
    Require all denied
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>

# Block access to sensitive file extensions
<FilesMatch "\.(env|log|bak|sql|csv|md|py|sh|ini)$">
    Require all denied
</FilesMatch>

# ─── Serve WebP variants when browser supports it ─────────────────────
# Example: /uploads/a.jpg -> /uploads/a.webp (if file exists and Accept includes image/webp)
RewriteCond %{HTTP_ACCEPT} image/webp [NC]
RewriteCond %{REQUEST_URI} ^(.+)\.(?:jpe?g|png)$ [NC]
RewriteCond %{DOCUMENT_ROOT}%1.webp -f
RewriteRule ^ %1.webp [T=image/webp,E=accept_webp:1,L]

<IfModule mod_headers.c>
    Header append Vary Accept env=accept_webp
    Header append Vary Accept env=REDIRECT_accept_webp
</IfModule>

# ─── Skip real files and directories ──────────────────────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ─── Arabic URL Routes ───────────────────────────────────────────────
# NEW: /ar/<path> is stripped by PHP language detection (REQUEST_URI-based)
# Apache just needs to pass /ar/... to index.php like any other path

# Legacy Arabic product URLs: /منتج/slug → redirect to /ar/slug
RewriteRule ^%D9%85%D9%86%D8%AA%D8%AC/(.+?)/?$ /ar/$1 [R=301,L]
RewriteRule ^منتج/(.+?)/?$ /ar/$1 [R=301,L]

# Legacy Arabic podcast URLs: /بودكاست → /ar/podcast
RewriteRule ^%D8%A8%D9%88%D8%AF%D9%83%D8%A7%D8%B3%D8%AA/?$ /ar/podcast [R=301,L]
RewriteRule ^بودكاست/?$ /ar/podcast [R=301,L]
RewriteRule ^%D8%A8%D9%88%D8%AF%D9%83%D8%A7%D8%B3%D8%AA/(.+?)/?$ /ar/podcast/$1 [R=301,L]
RewriteRule ^بودكاست/(.+?)/?$ /ar/podcast/$1 [R=301,L]

# Legacy Arabic store: /متجر → /ar/
RewriteRule ^%D9%85%D8%AA%D8%AC%D8%B1/?$ /ar/ [R=301,L]
RewriteRule ^متجر/?$ /ar/ [R=301,L]

# Legacy Arabic cart: /سلة → /ar/checkout
RewriteRule ^%D8%B3%D9%84%D8%A9/?$ /ar/pages/shop/guest_checkout.php [R=301,L]
RewriteRule ^سلة/?$ /ar/pages/shop/guest_checkout.php [R=301,L]

# ─── Podcast URLs ────────────────────────────────────────────────────
# /podcast → podcast.php (listing)
# /podcast/my-episode-slug → podcast.php?slug=my-episode-slug
RewriteRule ^podcast/?$ podcast.php [L,QSA]
RewriteRule ^podcast/([a-z0-9]+(?:-[a-z0-9]+)*)/?$ podcast.php?slug=$1 [L,QSA]

# ─── Category URLs ───────────────────────────────────────────────────
# /category/skincare → pages/shop/category.php?slug=skincare
RewriteRule ^category/([a-z0-9]+(?:-[a-z0-9]+)*)/?$ pages/shop/category.php?slug=$1 [L,QSA]

# ─── Clean product URLs ──────────────────────────────────────────────
# /the-ordinary-retinol → product.php?slug=the-ordinary-retinol
# BUT: Don't apply to /pages/ directory (admin, shop, auth, policies)
RewriteCond %{REQUEST_URI} !^/(pages)/
RewriteRule ^([a-z0-9]+(?:-[a-z0-9]+)*)/?$ product.php?slug=$1 [L,QSA]

# ─── Large File Uploads (500 MB) ──────────────────────────────────────
<IfModule mod_php.c>
    php_value upload_max_filesize 500M
    php_value post_max_size 512M
    php_value max_execution_time 600
    php_value max_input_time 600
    php_value memory_limit 256M
</IfModule>

# ─── Enable compression ──────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css application/javascript application/x-javascript application/json image/svg+xml image/x-icon font/ttf font/woff font/woff2 application/font-woff application/font-woff2
</IfModule>

# ─── Cache static assets ─────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>
